    <string name="actionable_steps">Actionable Steps</string>
    <string name="qa_note">Following this guidance significantly improves cocoon weight and quality.</string>

    <string name="adv_vent_title">Airflow &amp; Ventilation</string>
    <string name="adv_vent_tagline">Keep the rearing room fresh</string>
    <string name="adv_vent_content">Silkworms are highly sensitive to stagnant air. Proper ventilation ensures removal of excess CO2 and moisture, which are primary causes of Muscardine and other fungal diseases.</string>
    <string name="adv_vent_tip1">Open windows during the day for cross-ventilation.</string>
    <string name="adv_vent_tip2">Use fans if the air feels humid or heavy.</string>
    <string name="adv_vent_tip3">Avoid direct strong drafts on the silkworms.</string>
    <string name="adv_vent_tip4">Ensure ventilation is higher during late-age instars.</string>

    <string name="adv_clean_title">Hygiene &amp; Cleaning</string>
    <string name="adv_clean_tagline">Maintain a disease-free shed</string>
    <string name="adv_clean_content">Regular bed cleaning removes waste and uneaten leaves that rot and attract pathogens. A clean bed is essential for the healthy growth of the worms during their moulting stages.</string>
    <string name="adv_clean_tip1">Clean the rearing bed after every moult completed.</string>
    <string name="adv_clean_tip2">Wash hands with sanitizer before any handling.</string>
    <string name="adv_clean_tip3">Dispose of waste far away from the rearing shed.</string>
    <string name="adv_clean_tip4">Sprinkle lime powder to keep the bed dry after cleaning.</string>

    <string name="adv_feed_title">Feeding Management</string>
    <string name="adv_feed_tagline">Nutritious leaves for better silk</string>
    <string name="adv_feed_content">The growth of silkworms is directly proportional to the quality of mulberry leaves. Moisture content in leaves is vital for early instars, while maturity is needed for later stages.</string>
    <string name="adv_feed_tip1">Harvest leaves in early morning or late evening.</string>
    <string name="adv_feed_tip2">Store leaves under wet gunny bags to maintain moisture.</string>
    <string name="adv_feed_tip3">Never feed wilted, yellow or diseased leaves.</string>
    <string name="adv_feed_tip4">Regular feeding intervals promote uniform growth.</string>

    <string name="adv_ideal_title">Optimal Environment</string>
    <string name="adv_ideal_tagline">Ideal conditions for silkworms</string>
    <string name="adv_ideal_content">Maintaining optimal temperature and humidity is the foundation of successful sericulture. Silkworms thrive when their environment mimics natural spring conditions.</string>
    <string name="adv_ideal_tip1">Monitor temperature multiple times daily.</string>
    <string name="adv_ideal_tip2">Keep humidity within the stage-specific range.</string>
    <string name="adv_ideal_tip3">Avoid sudden environmental fluctuations.</string>
    <string name="adv_ideal_tip4">Ensure proper air quality in the rearing house.</string>

