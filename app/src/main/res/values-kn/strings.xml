    <!-- FAQ & Help -->
    <string name="faq_q1">ದೈನಂದಿನ ತಾಪಮಾನವನ್ನು ಹೇಗೆ ದಾಖಲಿಸುವುದು?</string>
    <string name="faq_a1">ಹೋಮ್ ಡ್ಯಾಶ್‌ಬೋರ್ಡ್‌ನಲ್ಲಿರುವ ಹವಾಮಾನ ದಾಖಲೆ ವಿಭಾಗಕ್ಕೆ ಹೋಗಿ ಮತ್ತು ಪ್ರಸ್ತುತ ರೀಡಿಂಗ್ ಅನ್ನು ನಮೂದಿಸಿ.</string>
    <string name="faq_q2">ನಾನು ಏಕಕಾಲದಲ್ಲಿ ಅನೇಕ ಬ್ಯಾಚ್‌ಗಳನ್ನು ನಿರ್ವಹಿಸಬಹುದೇ?</string>
    <string name="faq_a2">ಹೌದು, ಅಸ್ತಿತ್ವದಲ್ಲಿರುವ ಬ್ಯಾಚ್‌ಗಳ ಜೊತೆಗೆ ಹೊಸ ಬ್ಯಾಚ್ ಪ್ರಾರಂಭಿಸಲು ಬ್ಯಾಚ್ ಸೇರಿಸಿ ವಿಭಾಗವನ್ನು ಬಳಸಿ.</string>
    <string name="faq_q3">ಬದುಕುಳಿಯುವ ದರ ಕಡಿಮೆಯಾದರೆ ಏನು ಮಾಡಬೇಕು?</string>
    <string name="faq_a3">ಸಮಸ್ಯೆ ಪರಿಹಾರಕ್ಕಾಗಿ ಸ್ಮಾರ್ಟ್ ಸಲಹೆ ವಿಭಾಗವನ್ನು ಪರಿಶೀಲಿಸಿ.</string>

    <!-- Legal -->
    <string name="welcome_legal">ನಮ್ಮ ರೇಷ್ಮೆ ಅಪ್ಲಿಕೇಶನ್‌ಗೆ ಸುಸ್ವಾಗತ. ಈ ಅಪ್ಲಿಕೇಶನ್ ಬಳಸುವ ಮೂಲಕ, ನೀವು ಈ ಕೆಳಗಿನ ನಿಯಮ ಮತ್ತು ನಿಬಂಧನೆಗಳಿಗೆ ಒಪ್ಪುತ್ತೀರಿ:</string>
    <string name="legal_s1_title">1. ನಿಯಮಗಳ ಅಂಗೀಕಾರ</string>
    <string name="legal_s1_body">ನಮ್ಮ ರೇಷ್ಮೆ ಮೊಬೈಲ್ ಅಪ್ಲಿಕೇಶನ್ ಅನ್ನು ಪ್ರವೇಶಿಸುವ ಅಥವಾ ಬಳಸುವ ಮೂಲಕ, ನೀವು ಈ ಸೇವಾ ನಿಯಮಗಳನ್ನು ಓದಿದ್ದೀರಿ, ಅರ್ಥಮಾಡಿಕೊಂಡಿದ್ದೀರಿ ಮತ್ತು ಬದ್ಧರಾಗಿರಲು ಒಪ್ಪಿದ್ದೀರಿ ಎಂದು ಅಂಗೀಕರಿಸುತ್ತೀರಿ.</string>
    <string name="legal_s2_title">2. ಬಳಕೆದಾರರ ಖಾತೆಗಳು</string>
    <string name="legal_s2_body">ನಿಮ್ಮ ಖಾತೆಯ ಗೌಪ್ಯತೆಯನ್ನು ಕಾಪಾಡಿಕೊಳ್ಳಲು ನೀವು ಜವಾಬ್ದಾರರಾಗಿರುತ್ತೀರಿ. ನಿಮ್ಮ ಖಾತೆಯ ಅಡಿಯಲ್ಲಿ ನಡೆಯುವ ಎಲ್ಲಾ ಚಟುವಟಿಕೆಗಳಿಗೆ ನೀವೇ ಜವಾಬ್ದಾರರು.</string>
    <string name="legal_s3_title">3. ಡೇಟಾ ನಿಖರತೆ</string>
    <string name="legal_s3_body">ನೀವು ನಮೂದಿಸುವ ಡೇಟಾದ ಆಧಾರದ ಮೇಲೆ ಅಪ್ಲಿಕೇಶನ್ ಸಲಹೆಯನ್ನು ನೀಡುತ್ತದೆ. ನಾವು ನಿಖರತೆಗಾಗಿ ಶ್ರಮಿಸುತ್ತಿದ್ದರೂ, ಅಪ್ಲಿಕೇಶನ್ ಶಿಫಾರಸುಗಳ ಆಧಾರದ ಮೇಲೆ ತೆಗೆದುಕೊಂಡ ನಿರ್ಧಾರಗಳಿಂದ ಉಂಟಾಗುವ ಯಾವುದೇ ನಷ್ಟಗಳಿಗೆ ನಾವು ಜವಾಬ್ದಾರರಲ್ಲ.</string>
    <string name="legal_s4_title">4. ಬೌದ್ಧಿಕ ಆಸ್ತಿ</string>
    <string name="legal_s4_body">ಈ ಅಪ್ಲಿಕೇಶನ್‌ನ ವಿಷಯ, ಲೋಗೋ ಮತ್ತು ಸಾಫ್ಟ್‌ವೇರ್ ಹಕ್ಕುಸ್ವಾಮ್ಯ ಕಾನೂನುಗಳಿಂದ ರಕ್ಷಿಸಲ್ಪಟ್ಟಿದೆ ಮತ್ತು ಸಿಲ್ಕ್‌ಟೆಕ್ ಸೊಲ್ಯೂಷನ್ಸ್‌ಗೆ ಸೇರಿದೆ.</string>
    <string name="legal_s5_title">5. ಮಾರ್ಪಾಡುಗಳು</string>
    <string name="legal_s5_body">ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ಈ ನಿಯಮಗಳನ್ನು ಮಾರ್ಪಡಿಸುವ ಹಕ್ಕನ್ನು ನಾವು ಕಾಯ್ದಿರಿಸಿದ್ದೇವೆ.</string>

    <string name="privacy_welcome">ನಿಮ್ಮ ಗೌಪ್ಯತೆ ನಮಗೆ ಮುಖ್ಯವಾಗಿದೆ. ನಿಮ್ಮ ಡೇಟಾವನ್ನು ನಾವು ಹೇಗೆ ನಿರ್ವಹಿಸುತ್ತೇವೆ ಎಂಬ ವಿವರ ಇಲ್ಲಿದೆ:</string>
    <string name="priv_s1_title">ಡೇಟಾ ಸಂಗ್ರಹಣೆ</string>
    <string name="priv_s1_body">ವೈಯಕ್ತಿಕಗೊಳಿಸಿದ ಕೃಷಿ ಸಲಹೆ ಮತ್ತು ಹವಾಮಾನ ನವೀಕರಣಗಳನ್ನು ಒದಗಿಸಲು ನಾವು ಹೆಸರು, ಫೋನ್ ಸಂಖ್ಯೆ ಮತ್ತು ಸ್ಥಳದಂತಹ ವೈಯಕ್ತಿಕ ವಿವರಗಳನ್ನು ಸಂಗ್ರಹಿಸುತ್ತೇವೆ.</string>
    <string name="priv_s2_title">ಸ್ಥಳ ಪ್ರವೇಶ</string>
    <string name="priv_s2_body">ಸ್ಥಳೀಯ ಹವಾಮಾನವನ್ನು ಪಡೆಯಲು ಮತ್ತು ಸ್ಮಾರ್ಟ್ ಎಚ್ಚರಿಕೆಗಳಿಗಾಗಿ ನಿಮ್ಮ ಫಾರ್ಮ್ ನಿರ್ದೇಶಾಂಕಗಳನ್ನು ಸಿಂಕ್ ಮಾಡಲು ಸ್ಥಳ ಪ್ರವೇಶವನ್ನು ಬಳಸಲಾಗುತ್ತದೆ.</string>
    <string name="priv_s3_title">ಡೇಟಾ ಹಂಚಿಕೆ</string>
    <string name="priv_s3_body">ನಾವು ನಿಮ್ಮ ವೈಯಕ್ತಿಕ ಡೇಟಾವನ್ನು ಮೂರನೇ ವ್ಯಕ್ತಿಗಳಿಗೆ ಮಾರಾಟ ಮಾಡುವುದಿಲ್ಲ.</string>
    <string name="priv_s4_title">ಭದ್ರತೆ</string>
    <string name="priv_s4_body">ಅನಧಿಕೃತ ಪ್ರವೇಶದಿಂದ ನಿಮ್ಮ ಮಾಹಿತಿಯನ್ನು ರಕ್ಷಿಸಲು ನಾವು ಉದ್ಯಮ-ದರ್ಜೆಯ ಭದ್ರತಾ ಕ್ರಮಗಳನ್ನು ಅಳವಡಿಸುತ್ತೇವೆ.</string>

